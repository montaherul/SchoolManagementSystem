@model IEnumerable<school_management_system.Models.Attendance>

<h2>Student Attendance</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Date</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("dd-MMM-yyyy")</td>
                <td>@item.Status</td>
            </tr>
        }
    </tbody>
</table>