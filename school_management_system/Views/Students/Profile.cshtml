@model school_management_system.Models.Student

@{
    ViewData["Title"] = "Student Profile";
}

<div class="container mt-4">

    <h2 class="mb-4">Student Dashboard</h2>

    <div class="row">

        <!-- Student Profile Card -->
        <div class="col-md-4">

            <div class="card text-center shadow">

                <div class="card-body">

                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="@Model.PhotoPath"
                             width="120"
                             height="120"
                             style="border-radius:50%; object-fit:cover;" />
                    }
                    else
                    {
                        <img src="/images/students/default.png"
                             width="120"
                             height="120" />
                    }

                    <h4 class="mt-3">
                        @Model.FirstName @Model.LastName
                    </h4>

                    <p class="text-muted">
                        Admission: @Model.AdmissionNumber
                    </p>

                    <p>
                        Class:
                        @Model.Class?.ClassName -
                        @Model.Section?.SectionName
                    </p>

                    <span class="badge bg-success">
                        @Model.Status
                    </span>

                </div>

            </div>

        </div>


        <!-- Personal Information -->
        <div class="col-md-8">

            <div class="card shadow mb-3">

                <div class="card-header bg-primary text-white">
                    Personal Information
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6">
                            <strong>Date of Birth</strong><br />
                            @Model.DateOfBirth.ToString("dd MMM yyyy")
                        </div>

                        <div class="col-md-6">
                            <strong>Gender</strong><br />
                            @Model.Gender
                        </div>

                        <div class="col-md-12 mt-3">
                            <strong>Address</strong><br />
                            @Model.Address
                        </div>

                    </div>

                </div>

            </div>


            <!-- Parent Information -->
            <div class="card shadow mb-3">

                <div class="card-header bg-success text-white">
                    Parent Information
                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6">
                            <strong>Parent Name</strong><br />
                            @Model.ParentName
                        </div>

                        <div class="col-md-6">
                            <strong>Phone</strong><br />
                            @Model.ParentPhone
                        </div>

                        <div class="col-md-12 mt-3">
                            <strong>Email</strong><br />
                            @Model.ParentEmail
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>


    <!-- Quick Actions -->
    <div class="card shadow mt-3">

        <div class="card-header bg-dark text-white">
            Quick Actions
        </div>

        <div class="card-body text-center">

            <a asp-action="Edit"
                   asp-route-id="@Model.StudentID"
                   class="btn btn-primary m-2">
                Edit Profile
            </a>

            <a asp-controller="Attendances"
                   asp-action="StudentAttendance"
                   asp-route-id="@Model.StudentID"
                   class="btn btn-success m-2">
                View Attendance
            </a>

            <a class="btn btn-warning m-2">
                View Results
            </a>

            <a class="btn btn-info m-2">
                Fees Details
            </a>

        </div>

    </div>

</div>